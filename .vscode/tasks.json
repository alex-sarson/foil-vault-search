{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: start",
      "type": "shell",
      "command": "pnpm start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "label": "pnpm: test",
      "type": "shell",
      "command": "pnpm test",
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}

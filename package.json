{
  "name": "foil-vault-search",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "start": "concurrently -k -n api,web -c blue,green \"pnpm --filter @foil-vault/api start\" \"wait-on http://127.0.0.1:3000/health && pnpm --filter @foil-vault/web start\"",
    "start:api": "pnpm --filter @foil-vault/api start",
    "start:web": "pnpm --filter @foil-vault/web start",
    "build": "pnpm --filter @foil-vault/api build && pnpm --filter @foil-vault/web build",
    "test": "pnpm --filter @foil-vault/web test -- --no-watch --browsers=ChromeHeadless",
    "test:watch": "pnpm --filter @foil-vault/web test",
    "ingest": "pnpm --filter @foil-vault/api ingest"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.2"
  }
}
